{
  "name": "forjegames",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "next dev --turbo",
    "dev:api": "npm run dev --workspace=apps/api",
    "postinstall": "prisma generate",
    "build": "next build",
    "build:web": "next build",
    "lint": "next lint && npm run lint --workspace=apps/api",
    "typecheck": "tsc --noEmit && npm run typecheck --workspace=apps/api",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron-build": "electron-builder --win --mac",
    "electron-build:win": "electron-builder --win",
    "electron-build:mac": "electron-builder --mac",
    "mcp:start": "node packages/mcp/start-all.js",
    "mcp:start:prod": "node packages/mcp/start-all.js --prod",
    "mcp:build": "npm run build --workspace=packages/mcp/asset-alchemist && npm run build --workspace=packages/mcp/city-architect && npm run build --workspace=packages/mcp/terrain-forge"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.0.0",
    "@prisma/client": "^6.0.0",
    "@react-email/components": "^1.0.10",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@sentry/nextjs": "^10.46.0",
    "@types/three": "^0.183.1",
    "@vercel/og": "^0.11.1",
    "bullmq": "^5.72.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.4.1",
    "lucide-react": "^0.460.0",
    "next": "^15.0.0",
    "posthog-js": "^1.157.0",
    "posthog-node": "^5.28.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-email": "^5.2.10",
    "recharts": "^3.8.1",
    "resend": "^6.9.4",
    "rollup": "^4.60.1",
    "server-only": "^0.0.1",
    "stripe": "^17.0.0",
    "svix": "^1.89.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^2.5.4",
    "three": "^0.183.2",
    "typescript": "^5.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "happy-dom": "^20.8.9",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.0"
  }
}
