{
  "name": "forjegames",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "next dev --turbo",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:full": "node scripts/start-dev.js",
    "predev": "node scripts/check-deps.js",
    "postinstall": "prisma generate",
    "build": "next build",
    "build:web": "next build",
    "start": "next start",
    "lint": "next lint && npm run lint --workspace=apps/api",
    "typecheck": "tsc --noEmit && npm run typecheck --workspace=apps/api",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:shadow": "docker compose -f docker-compose.shadow-db.yml up -d",
    "db:shadow:down": "docker compose -f docker-compose.shadow-db.yml down",
    "seed:templates": "npx tsx src/scripts/seed-templates.ts",
    "verify:clerk": "tsx scripts/verify-clerk-keys.ts",
    "secrets:generate": "tsx scripts/generate-secrets.ts",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron-build": "electron-builder --win --mac",
    "electron-build:win": "electron-builder --win",
    "electron-build:mac": "electron-builder --mac",
    "mcp:start": "node packages/mcp/start-all.js",
    "mcp:start:prod": "node packages/mcp/start-all.js --prod",
    "mcp:build": "npm run build --workspace=packages/mcp/asset-alchemist && npm run build --workspace=packages/mcp/city-architect && npm run build --workspace=packages/mcp/terrain-forge"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.87.0",
    "@clerk/nextjs": "^6.0.0",
    "@huggingface/transformers": "^4.1.0",
    "@prisma/client": "^6.0.0",
    "@react-email/components": "^1.0.10",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@sentry/nextjs": "^10.46.0",
    "@types/three": "^0.183.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/og": "^0.11.1",
    "bullmq": "^5.72.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.0",
    "groq-sdk": "^1.1.2",
    "ioredis": "^5.4.1",
    "jose": "^6.2.2",
    "luau-web": "^1.4.0",
    "lucide-react": "^0.460.0",
    "next": "^15.0.0",
    "next-intl": "^3.26.0",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0",
    "posthog-js": "^1.372.3",
    "posthog-node": "^5.30.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-email": "^5.2.10",
    "recharts": "^3.8.1",
    "resend": "^6.9.4",
    "rollup": "^4.60.1",
    "server-only": "^0.0.1",
    "stripe": "^17.0.0",
    "svix": "^1.89.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^2.5.4",
    "three": "^0.183.2",
    "twilio": "^5.13.1",
    "typescript": "^5.6.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.9",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.0.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.0.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "happy-dom": "^20.8.9",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "vitest": "^4.1.4",
    "wait-on": "^8.0.0",
    "youtube-transcript": "^1.3.0"
  }
}
