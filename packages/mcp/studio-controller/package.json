{
  "name": "@forjegames/mcp-studio-controller",
  "version": "1.0.0",
  "description": "MCP server for direct read/write control of Roblox Studio state via local plugin HTTP endpoint",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-studio-controller": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
