# =============================================================================
# RobloxForge — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is in .gitignore.
# =============================================================================

# =============================================================================
# DATABASE
# =============================================================================
# Pooled connection (used by Prisma at runtime via PgBouncer / Supabase pooler)
DATABASE_URL="postgresql://user:pass@localhost:5432/robloxforge"
# Direct connection (used by Prisma for migrations & introspection — bypasses pooler)
DIRECT_URL="postgresql://user:pass@localhost:5432/robloxforge"

# =============================================================================
# REDIS / UPSTASH
# Choose one: classic self-hosted Redis OR Upstash REST API.
# Upstash is recommended for serverless/edge deployments.
# =============================================================================
REDIS_URL="redis://localhost:6379"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# =============================================================================
# AUTH — CLERK
# https://dashboard.clerk.com
# =============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."
# Optional: RS256 JWT verification key (base64-encoded PEM)
CLERK_JWT_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/editor"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# =============================================================================
# PAYMENTS — STRIPE
# https://dashboard.stripe.com
# STRIPE_SECRET_KEY and STRIPE_WEBHOOK_SECRET are REQUIRED in production.
# =============================================================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_RESTRICTED_KEY=""
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Price IDs — create these in the Stripe dashboard
STRIPE_FREE_PRICE_ID=""
STRIPE_HOBBY_PRICE_ID=""
STRIPE_HOBBY_YEARLY_PRICE_ID=""
STRIPE_CREATOR_PRICE_ID=""
STRIPE_CREATOR_YEARLY_PRICE_ID=""
STRIPE_STUDIO_PRICE_ID=""
STRIPE_STUDIO_YEARLY_PRICE_ID=""
STRIPE_TOKEN_STARTER_PRICE_ID=""
STRIPE_TOKEN_CREATOR_PRICE_ID=""
STRIPE_TOKEN_PRO_PRICE_ID=""
STRIPE_CHARITY_ACCOUNT_ID=""

# =============================================================================
# AI PROVIDERS
# All are optional in dev; ANTHROPIC_API_KEY is REQUIRED in production.
# Set ANTHROPIC_DISABLED=true to skip all Anthropic API calls (e.g. in CI or
# when running Groq-only mode).
# =============================================================================
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_DISABLED=""
GEMINI_API_KEY=""
# Groq LLM fallback — https://console.groq.com — used by src/lib/ai/provider.ts
GROQ_API_KEY=""
# Meshy 3D generation — https://www.meshy.ai
MESHY_API_KEY=""
# Meshy webhook signature secret — set in the Meshy dashboard under Webhooks
MESHY_WEBHOOK_SECRET=""
# fal.ai image/video generation — SDK reads FAL_KEY specifically (not FAL_API_KEY)
FAL_KEY=""
# FAL_API_KEY is an alias for FAL_KEY used by some fal.ai integrations
FAL_API_KEY=""
DEEPGRAM_API_KEY=""
ELEVENLABS_API_KEY=""
OPENAI_API_KEY=""

# =============================================================================
# EMAIL — RESEND
# https://resend.com — REQUIRED in production.
# RESEND_AUDIENCE_ID — audience ID for email marketing list management
# UNSUBSCRIBE_SECRET — HMAC key used to sign/verify email unsubscribe links
# =============================================================================
RESEND_API_KEY="re_..."
RESEND_AUDIENCE_ID=""
UNSUBSCRIBE_SECRET=""

# =============================================================================
# SMS — TWILIO
# https://twilio.com — OPTIONAL. Enables SMS notifications.
# =============================================================================
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# =============================================================================
# ANALYTICS — POSTHOG
# https://posthog.com
# NEXT_PUBLIC_POSTHOG_KEY — client-side (browser) tracking
# POSTHOG_API_KEY — server-side event tracking (same project, different key type)
# =============================================================================
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
POSTHOG_API_KEY=""
POSTHOG_HOST="https://app.posthog.com"

# =============================================================================
# ERROR MONITORING — SENTRY
# https://sentry.io
# NEXT_PUBLIC_SENTRY_DSN — frontend (browser)
# SENTRY_DSN — backend / edge (server-side SDK)
# =============================================================================
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# =============================================================================
# UPTIME MONITORING
# =============================================================================
BETTER_UPTIME_API_KEY=""

# =============================================================================
# SECURITY / INFRA
# CRON_SECRET is REQUIRED in production to protect cron endpoints.
# TOKEN_HASH_SECRET — HMAC key for hashSecret()/hashToken(), must be ≥32 random chars.
# WORKER_SECRET — optional bearer token for worker→server internal calls.
# HEALTH_CHECK_SECRET — Bearer token required to access detailed /api/health output.
# =============================================================================
CRON_SECRET=""
TOKEN_HASH_SECRET=""
WORKER_SECRET=""
HEALTH_CHECK_SECRET=""
# Comma-separated admin emails
ADMIN_EMAILS=""

# =============================================================================
# ROBLOX INTEGRATION
# https://create.roblox.com/dashboard/credentials
# ROBLOX_CREATOR_TYPE — "User" or "Group"
# =============================================================================
ROBLOX_OPEN_CLOUD_API_KEY=""
ROBLOX_CREATOR_ID=""
ROBLOX_CREATOR_TYPE="User"

# =============================================================================
# STUDIO PLUGIN AUTH
# STUDIO_AUTH_SECRET — JWT signing key used to authenticate requests from the
#                      Studio plugin; must be a long random string (≥32 chars).
# STUDIO_PLUGIN_SECRET — Shared handshake secret for the Studio plugin pairing
#                        flow; rotate this to invalidate all active plugin sessions.
# =============================================================================
STUDIO_AUTH_SECRET=""
STUDIO_PLUGIN_SECRET=""

# =============================================================================
# MCP SERVERS
# Base URLs for the three ForjeGames MCP servers.
# Defaults (localhost) are used when these vars are unset in development.
# In production, point to your deployed MCP service URLs.
# =============================================================================
MCP_ASSET_ALCHEMIST_URL=http://localhost:3002
MCP_CITY_ARCHITECT_URL=http://localhost:3003
MCP_TERRAIN_FORGE_URL=http://localhost:3004

# =============================================================================
# APP ROUTING
# =============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001"
API_URL="http://localhost:3001"
ALLOWED_ORIGINS="http://localhost:3000"
PORT="3001"

# =============================================================================
# AWS / BACKUPS (optional — used by scripts/backup.sh)
# =============================================================================
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
BACKUP_S3_BUCKET="robloxforge-db-backups"

# =============================================================================
# MAINTENANCE MODE
# Set MAINTENANCE_MODE=true to serve the maintenance page to all visitors.
# MAINTENANCE_UNTIL — ISO 8601 datetime string shown as ETA on the maintenance
#                     page (e.g. "2026-04-05T18:00:00Z"). Leave empty to omit.
# NEXT_PUBLIC_DISCORD_URL — Discord invite link shown on the maintenance page.
# NEXT_PUBLIC_STATUS_PAGE_URL — Status page URL shown on the maintenance page.
# =============================================================================
MAINTENANCE_MODE=""
MAINTENANCE_UNTIL=""
NEXT_PUBLIC_DISCORD_URL=""
NEXT_PUBLIC_STATUS_PAGE_URL=""

# =============================================================================
# FEATURE FLAGS
# Set DEMO_MODE=true to bypass all auth gates in local dev or staging.
# Set to false (or remove) when Clerk production keys are active.
# =============================================================================
DEMO_MODE="true"
NEXT_PUBLIC_DEMO_MODE="true"
