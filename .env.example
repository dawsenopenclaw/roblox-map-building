# ForjeGames environment configuration — example values.
# Copy to `.env.local` and fill in real secrets.

# ── Mesh generation pipeline ────────────────────────────────────────────────
# Meshy AI key — text-to-3d + image-to-3d. Get one at https://meshy.ai
MESHY_API_KEY=

# Roblox Open Cloud API key with Asset:Write scope.
# Create at https://create.roblox.com/dashboard/credentials
ROBLOX_OPEN_CLOUD_KEY=

# Numeric Roblox user or group ID that will own generated assets.
ROBLOX_CREATOR_ID=

# "User" (default) or "Group"
ROBLOX_CREATOR_TYPE=User
