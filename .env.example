# ═══════════════════════════════════════════════════════════════════════════
# ForjeGames — environment configuration template
# ═══════════════════════════════════════════════════════════════════════════
#
# Copy this file to `.env.local` (dev) or paste each value into your Vercel
# project's Environment Variables screen (prod). Required variables for
# production are marked [REQUIRED]. Optional ones are marked [OPTIONAL].
# Deployment fails fast with a helpful error for REQUIRED vars that are
# missing — search the codebase for the variable name to find the helper
# that throws (e.g. src/lib/studio-auth-secret.ts, src/lib/env.ts).
#
# Last updated: 2026-04-11
#
# ═══════════════════════════════════════════════════════════════════════════

# ── App + database ──────────────────────────────────────────────────────────

# [REQUIRED] Public URL used for Stripe success/cancel redirects and Clerk.
NEXT_PUBLIC_APP_URL=https://forjegames.com

# [REQUIRED] Primary Postgres connection string (used by Prisma client).
# pgvector extension must be enabled in this database for RAG to work —
# run `CREATE EXTENSION IF NOT EXISTS vector;` on Neon/Supabase/self-hosted
# before `prisma migrate deploy`. Vercel Postgres needs the Neon add-on.
DATABASE_URL=postgresql://user:pass@host:5432/forjegames

# [OPTIONAL] Separate shadow database Prisma uses for `migrate dev`.
# Must also have pgvector installed. Defaults to an in-memory shadow if
# omitted, which doesn't work with the vector column types.
SHADOW_DATABASE_URL=postgresql://user:pass@host:5433/forjegames_shadow

# [REQUIRED] Upstash Redis or local Redis for rate limits + session store
# + command queue + build progress. Used everywhere.
REDIS_URL=rediss://default:token@region.upstash.io:6379

# ── Authentication (Clerk) ──────────────────────────────────────────────────

# [REQUIRED] Clerk publishable key — safe to expose to the browser.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...

# [REQUIRED] Clerk secret key — server-side only, never expose.
CLERK_SECRET_KEY=sk_live_...

# [REQUIRED] Clerk webhook signing secret. Used by
# src/app/api/webhooks/clerk/route.ts to validate user lifecycle events.
CLERK_WEBHOOK_SECRET=whsec_...

# ── Billing (Stripe) ────────────────────────────────────────────────────────

# [REQUIRED for paid tiers] Stripe secret key. When missing, all checkout
# routes return 503 "Stripe not configured yet" instead of crashing.
STRIPE_SECRET_KEY=sk_live_...

# [REQUIRED for paid tiers] Stripe publishable key — safe to expose.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# [REQUIRED for paid tiers] Stripe webhook signing secret — used by
# src/app/api/webhooks/stripe/route.ts to validate subscription.created,
# invoice.paid, customer.subscription.updated etc.
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Subscription tier Price IDs ────────────────────────────────────────────
# Create these in your Stripe Dashboard → Products → Prices. Each tier
# needs one monthly + one yearly Price ID. The $10 "Starter" tier is
# internally keyed as HOBBY in the DB — that's the legacy name that still
# appears in the env var name below.

# Starter — $10/mo, $96/yr (5,000 tokens)
STRIPE_HOBBY_PRICE_ID=price_...
STRIPE_HOBBY_YEARLY_PRICE_ID=price_...

# Creator — $50/mo, $480/yr (30,000 tokens)
STRIPE_CREATOR_PRICE_ID=price_...
STRIPE_CREATOR_YEARLY_PRICE_ID=price_...

# Studio — $200/mo, $1920/yr (150,000 tokens)
STRIPE_STUDIO_PRICE_ID=price_...
STRIPE_STUDIO_YEARLY_PRICE_ID=price_...

# ── Token-pack Price IDs (one-time purchases) ──────────────────────────────
# Separate from subscription tiers. Users can top up tokens without an
# active subscription. All three are optional — if you don't set them,
# the /pricing page shows a "Contact us" fallback for that token pack.

STRIPE_TOKEN_STARTER_PRICE_ID=price_...   # $10, 1000 tokens
STRIPE_TOKEN_CREATOR_PRICE_ID=price_...   # $45, 5000 tokens
STRIPE_TOKEN_PRO_PRICE_ID=price_...       # $120, 15000 tokens

# ── Roblox Studio plugin auth ──────────────────────────────────────────────

# [REQUIRED] 32+ character secret used to sign the JWTs the web app issues
# to paired Roblox Studio plugins. All three studio routes (auth, sync,
# execute) share this secret via src/lib/studio-auth-secret.ts — they
# fail-loud at boot in production if this is missing or too short.
# Generate one with:   openssl rand -hex 32
STUDIO_AUTH_SECRET=

# ── Roblox Open Cloud (asset uploads) ──────────────────────────────────────

# [REQUIRED] Roblox Open Cloud API key with Asset:Write scope. Used by
# the mesh/texture pipeline to upload generated assets into the creator's
# Roblox account. Create at:
# https://create.roblox.com/dashboard/credentials
ROBLOX_OPEN_CLOUD_KEY=

# [REQUIRED] Numeric Roblox user or group ID that owns generated assets.
ROBLOX_CREATOR_ID=

# "User" (default) or "Group"
ROBLOX_CREATOR_TYPE=User

# ── Robux purchase flow (optional alternative to Stripe) ────────────────────
# Users without a credit card can buy credits with Robux inside the
# ForjeGames Roblox experience. Requires a real published experience with
# GamePasses and DevProducts created via Creator Dashboard.

# [REQUIRED for Robux] ID of the published ForjeGames experience on Roblox.
# Find it in the URL: https://www.roblox.com/games/<ROBLOX_EXPERIENCE_ID>/
ROBLOX_EXPERIENCE_ID=

# [REQUIRED for Robux] Shared secret used by the server script
# (packages/robux-payment/GamePassHandler.lua) to authenticate the webhook
# POST to /api/webhooks/roblox. The server does constant-time comparison
# on the x-roblox-webhook-secret header. Must match the WEBHOOK_SECRET
# constant inside your installed GamePassHandler.lua file.
# Generate one with:   openssl rand -hex 32
# Legacy name ROBLOX_WEBHOOK_SECRET is also accepted for back-compat.
ROBUX_WEBHOOK_SECRET=

# [REQUIRED for Robux] Per-tier GamePass IDs.  Empty values make the
# /api/billing/robux route return a 503 for that tier.
ROBLOX_GAMEPASS_STARTER_ID=
ROBLOX_GAMEPASS_PRO_ID=
ROBLOX_GAMEPASS_STUDIO_ID=

# [REQUIRED for Robux] Per-pack DevProduct IDs (repeatable credit buys).
ROBLOX_DEVPRODUCT_CREDITS_100_ID=
ROBLOX_DEVPRODUCT_CREDITS_500_ID=

# ── AI providers ────────────────────────────────────────────────────────────

# [REQUIRED] Primary LLM — Google Gemini. Used by callAI() in most routes.
GEMINI_API_KEY=

# [OPTIONAL] Fallback LLM — Groq. Used when Gemini fails or rate-limits.
GROQ_API_KEY=

# [OPTIONAL] Anthropic Claude key. Used for the optional custom-key path
# in the build executor. Most routes don't need this.
ANTHROPIC_API_KEY=

# [REQUIRED for image/texture generation] Fal AI key.
# Either name works — some routes check FAL_KEY, others FAL_API_KEY.
FAL_KEY=
FAL_API_KEY=

# [REQUIRED for mesh generation] Meshy AI key — text-to-3d and image-to-3d.
# Get one at https://meshy.ai
MESHY_API_KEY=

# ── Observability ───────────────────────────────────────────────────────────

# [OPTIONAL] Sentry DSN for error reporting. Clients + server.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# [OPTIONAL] PostHog product analytics.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Other ───────────────────────────────────────────────────────────────────

# [OPTIONAL] Comma-separated list of admin Clerk user emails. Users whose
# email is in this list bypass token-spend + rate-limit checks in /api/ai/*
# so admins can smoke-test paid flows without consuming credits.
ADMIN_EMAILS=

# [OPTIONAL] Set DEMO_MODE=true to bypass auth/tier/credit checks entirely.
# Used for screenshots, CI smoke tests, and the showcase page. Do NOT set
# this in a live production environment.
DEMO_MODE=false
