  }

  for i, action in ipairs(actions) do
    local yPos = 40 + (i - 1) * 40
    actionButtons[i] = makeActionBtn(actionsCard, action.text, yPos, action.primary)
  end

  actionsCard.Size = UDim2.new(1, 0, 0, 40 + #actions * 40 + 8)

