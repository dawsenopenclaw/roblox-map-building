generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth / Identity ───────────────────────────────────────────────────────

model User {
  id                    String    @id @default(cuid())
  clerkId               String    @unique
  email                 String    @unique
  username              String?   @unique
  displayName           String?
  avatarUrl             String?
  dateOfBirth           DateTime?
  isUnder13             Boolean   @default(false)
  parentEmail           String?
  parentConsentAt       DateTime?
  parentConsentToken    String?   @unique
  parentConsentTokenExp DateTime?
  role                  UserRole  @default(USER)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  subscription  Subscription?
  tokenBalance  TokenBalance?
  charityChoice String?
  donations     CharityDonation[]
  auditLogs     AuditLog[]
  apiUsage      ApiUsageRecord[]

  // Marketplace
  createdTemplates  Template[]           @relation("CreatedTemplates")
  boughtTemplates   TemplatePurchase[]   @relation("BoughtTemplates")
  authoredReviews   TemplateReview[]     @relation("AuthoredReviews")
  creatorAccount    CreatorAccount?

  // Gamification
  userXp           UserXP?
  userAchievements UserAchievement[]
  streak           Streak?

  @@index([clerkId])
  @@index([email])
}

enum UserRole {
  USER
  ADMIN
  CREATOR
}

// ─── Subscriptions & Billing ───────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  tier                 SubscriptionTier   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  trialEnd             DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([stripeCustomerId])
  @@index([userId])
}

enum SubscriptionTier {
  FREE
  HOBBY
  CREATOR
  STUDIO
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
  PAUSED
}

// ─── Token Economy ─────────────────────────────────────────────────────────

model TokenBalance {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance        Int      @default(0)
  lifetimeEarned Int      @default(0)
  lifetimeSpent  Int      @default(0)
  rolloverTokens Int      @default(0)
  updatedAt      DateTime @updatedAt

  transactions TokenTransaction[]
}

model TokenTransaction {
  id          String               @id @default(cuid())
  balanceId   String
  balance     TokenBalance         @relation(fields: [balanceId], references: [id])
  type        TokenTransactionType
  amount      Int
  description String
  metadata    Json?
  createdAt   DateTime             @default(now())

  @@index([balanceId])
  @@index([createdAt])
}

enum TokenTransactionType {
  PURCHASE
  SPEND
  REFUND
  BONUS
  ROLLOVER
  SUBSCRIPTION_GRANT
}

// ─── Charity ───────────────────────────────────────────────────────────────

model CharityDonation {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id])
  stripeTransferId String?        @unique
  charitySlug      String
  charityName      String
  amountCents      Int
  sourcePurchaseId String?
  status           DonationStatus @default(PENDING)
  createdAt        DateTime       @default(now())
  processedAt      DateTime?

  @@index([userId])
  @@index([createdAt])
}

enum DonationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── Audit Logging ─────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  resource   String
  resourceId String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([resource, resourceId])
}

// ─── API Usage Tracking ────────────────────────────────────────────────────

model ApiUsageRecord {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  provider   String
  operation  String
  tokensUsed Int      @default(0)
  costUsd    Float    @default(0)
  durationMs Int?
  success    Boolean  @default(true)
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([provider])
  @@index([createdAt])
}

// ─── Cost Tracking (aggregated daily) ──────────────────────────────────────

model DailyCostSnapshot {
  id            String   @id @default(cuid())
  date          DateTime @unique @db.Date
  providerCosts Json
  totalCostUsd  Float
  totalRevenue  Float
  margin        Float
  createdAt     DateTime @default(now())

  @@index([date])
}

// ─── Marketplace ────────────────────────────────────────────────────────────

enum TemplateCategory {
  GAME_TEMPLATE
  MAP_TEMPLATE
  UI_KIT
  SCRIPT
  ASSET
  SOUND
}

enum TemplateStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

model Template {
  id              String           @id @default(cuid())
  creatorId       String
  creator         User             @relation("CreatedTemplates", fields: [creatorId], references: [id])
  title           String
  description     String           @db.Text
  category        TemplateCategory
  status          TemplateStatus   @default(DRAFT)
  priceCents      Int              @default(0)
  rbxmFileUrl     String?
  thumbnailUrl    String?
  tags            String[]
  downloads       Int              @default(0)
  averageRating   Float            @default(0)
  reviewCount     Int              @default(0)
  stripeProductId String?
  stripePriceId   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  screenshots TemplateScreenshot[]
  reviews     TemplateReview[]
  purchases   TemplatePurchase[]

  @@index([creatorId])
  @@index([category])
  @@index([status])
  @@index([createdAt])
  @@index([averageRating])
  @@index([downloads])
}

model TemplateScreenshot {
  id         String   @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  url        String
  altText    String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([templateId])
}

model TemplateReview {
  id              String    @id @default(cuid())
  templateId      String
  template        Template  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  reviewerId      String
  reviewer        User      @relation("AuthoredReviews", fields: [reviewerId], references: [id])
  purchaseId      String    @unique
  purchase        TemplatePurchase @relation(fields: [purchaseId], references: [id])
  rating          Int
  body            String?   @db.Text
  creatorResponse String?   @db.Text
  respondedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([templateId])
  @@index([reviewerId])
}

model TemplatePurchase {
  id                    String   @id @default(cuid())
  templateId            String
  template              Template @relation(fields: [templateId], references: [id])
  buyerId               String
  buyer                 User     @relation("BoughtTemplates", fields: [buyerId], references: [id])
  stripePaymentIntentId String?  @unique
  amountCents           Int
  platformFeeCents      Int
  creatorPayoutCents    Int
  stripeTransferId      String?  @unique
  payoutStatus          PayoutStatus @default(PENDING)
  createdAt             DateTime @default(now())

  review TemplateReview?

  @@index([templateId])
  @@index([buyerId])
  @@index([createdAt])
}

enum PayoutStatus {
  PENDING
  PAID
  FAILED
}

model CreatorAccount {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeAccountId       String   @unique
  chargesEnabled        Boolean  @default(false)
  payoutsEnabled        Boolean  @default(false)
  detailsSubmitted      Boolean  @default(false)
  pendingBalanceCents   Int      @default(0)
  totalEarnedCents      Int      @default(0)
  lastPayoutAt          DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
}

// ─── Gamification ───────────────────────────────────────────────────────────

model UserXP {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalXp       Int      @default(0)
  tier          XPTier   @default(NOVICE)
  dailyXpToday  Int      @default(0)
  dailyXpDate   DateTime @default(now()) @db.Date
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  xpEvents XPEvent[]

  @@index([userId])
  @@index([totalXp])
}

enum XPTier {
  NOVICE
  APPRENTICE
  BUILDER
  MASTER
  LEGEND
  MYTHIC
}

enum XPEventType {
  BUILD
  PUBLISH
  SALE
  REFERRAL
  ACHIEVEMENT
  STREAK_BONUS
  DAILY_LOGIN
}

model XPEvent {
  id        String      @id @default(cuid())
  userXpId  String
  userXp    UserXP      @relation(fields: [userXpId], references: [id], onDelete: Cascade)
  type      XPEventType
  amount    Int
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([userXpId])
  @@index([createdAt])
}

model Achievement {
  id          String              @id @default(cuid())
  slug        String              @unique
  name        String
  description String
  icon        String
  category    AchievementCategory
  xpReward    Int                 @default(0)
  condition   Json
  createdAt   DateTime            @default(now())

  userAchievements UserAchievement[]
}

enum AchievementCategory {
  FIRST_STEPS
  VELOCITY
  MARKETPLACE
  COMMUNITY
  QUALITY
  EXPLORATION
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  unlockedAt    DateTime    @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
}

model Streak {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  loginStreak         Int      @default(0)
  buildStreak         Int      @default(0)
  longestLoginStreak  Int      @default(0)
  longestBuildStreak  Int      @default(0)
  lastLoginDate       DateTime @default(now()) @db.Date
  lastBuildDate       DateTime @default(now()) @db.Date
  totalLogins         Int      @default(0)
  totalBuilds         Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
}

// ─── Game DNA Scanner ──────────────────────────────────────────────────────

model GameScan {
  id            String     @id @default(cuid())
  userId        String
  robloxUrl     String
  robloxPlaceId String?
  gameName      String?
  status        ScanStatus @default(PENDING)
  errorMsg      String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  genome GameGenome?

  @@index([userId])
  @@index([createdAt])
  @@index([robloxPlaceId])
}

enum ScanStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
}

model GameGenome {
  id                String   @id @default(cuid())
  scanId            String   @unique
  scan              GameScan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  // 12-variable genome
  gameType          String
  targetAge         String
  sessionLength     String
  monetizationModel String
  progressionPace   String
  zoneDensity       String
  artStyle          String
  retentionDriver   String
  estimatedDau      String
  engagementLoop    String
  updateCadence     String
  communitySize     String

  // Raw scores 0-100 for radar chart
  scores            Json

  // Genre averages for comparison
  genreAverages     Json?

  // Analysis metadata
  rawRobloxData     Json?
  visionAnalysis    Json?
  recommendations   Json

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([scanId])
}

// ─── Team Collaboration ────────────────────────────────────────────────────

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  slug        String   @unique
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members    TeamMember[]
  invites    TeamInvite[]
  versions   ProjectVersion[]
  activities TeamActivity[]

  @@index([ownerId])
  @@index([slug])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  role      TeamRole @default(VIEWER)
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  lockedZones ZoneLock[]

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

enum TeamRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

model TeamInvite {
  id         String       @id @default(cuid())
  teamId     String
  team       Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedBy  String
  email      String?
  token      String       @unique @default(cuid())
  role       TeamRole     @default(EDITOR)
  status     InviteStatus @default(PENDING)
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime     @default(now())

  @@index([teamId])
  @@index([token])
  @@index([email])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model TeamActivity {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId      String
  action      String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([teamId])
  @@index([userId])
  @@index([createdAt])
}

model ZoneLock {
  id           String     @id @default(cuid())
  teamMemberId String
  member       TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  zoneId       String
  zoneName     String?
  lockedAt     DateTime   @default(now())
  expiresAt    DateTime

  @@unique([zoneId])
  @@index([teamMemberId])
  @@index([zoneId])
}

model ProjectVersion {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  projectId String
  userId    String
  version   Int
  message   String?
  snapshot  Json
  createdAt DateTime @default(now())

  diffs   VersionDiff[] @relation("FromVersion")
  diffsTo VersionDiff[] @relation("ToVersion")

  @@index([teamId])
  @@index([projectId])
  @@index([createdAt])
}

model VersionDiff {
  id            String         @id @default(cuid())
  fromVersionId String
  fromVersion   ProjectVersion @relation("FromVersion", fields: [fromVersionId], references: [id])
  toVersionId   String
  toVersion     ProjectVersion @relation("ToVersion", fields: [toVersionId], references: [id])
  diff          Json
  summary       String?
  createdAt     DateTime       @default(now())

  @@index([fromVersionId])
  @@index([toVersionId])
}
