generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  // Connection pool: max 10 connections, 20s timeout, prepared statements enabled
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
  // Shadow DB used by `prisma migrate dev` to diff against schema. Must have
  // the `vector` (pgvector) extension installed — our migration
  // 20260406000000_add_pgvector_rag runs `CREATE EXTENSION vector`, which
  // fails on a stock local Postgres. See docs/PGVECTOR_SHADOW_DB.md for setup.
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ─── Auth / Identity ───────────────────────────────────────────────────────

model User {
  id                    String    @id @default(cuid())
  clerkId               String    @unique
  email                 String    @unique
  username              String?   @unique
  displayName           String?
  avatarUrl             String?
  dateOfBirth           DateTime?
  isUnder13             Boolean   @default(false)
  parentEmail           String?
  parentConsentAt       DateTime?
  parentConsentToken    String?   @unique
  parentConsentTokenExp DateTime?
  role                  UserRole  @default(USER)
  marketingEmailsOptOut Boolean   @default(false)
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  // Referral code — server-generated UUID, stored for stable link sharing
  referralCode          String?   @unique
  // Monthly referral reward cap — tracks count + billing month (YYYY-MM)
  monthlyReferralCount  Int       @default(0)
  monthlyReferralMonth  String    @default("")

  subscription  Subscription?
  tokenBalance  TokenBalance?
  charityChoice String?
  donations     CharityDonation[]
  auditLogs     AuditLog[]
  apiUsage      ApiUsageRecord[]

  // Marketplace
  createdTemplates Template[]         @relation("CreatedTemplates")
  boughtTemplates  TemplatePurchase[] @relation("BoughtTemplates")
  authoredReviews  TemplateReview[]   @relation("AuthoredReviews")
  creatorAccount   CreatorAccount?

  // Gamification
  userXp           UserXP?
  userAchievements UserAchievement[]
  streak           Streak?

  // API Keys & Webhooks
  apiKeys          ApiKey[]
  webhookEndpoints WebhookEndpoint[]

  // Referrals
  referralsMade    Referral[] @relation("ReferrerReferrals")
  referralReceived Referral[] @relation("ReferredReferrals")

  // Roblox Identity (populated from Roblox OAuth on signup)
  robloxUserId      String?   @unique // Roblox numeric user ID
  robloxUsername    String? // Roblox username (can change)
  robloxDisplayName String? // Roblox display name
  robloxAvatarUrl   String? // Roblox avatar thumbnail URL
  robloxVerifiedAt  DateTime? // When Roblox account was linked

  // Profile
  bio           String?
  twitterHandle String?
  discordHandle String?
  githubHandle  String?
  robloxHandle  String?

  // Phone (for SMS notifications)
  phone String?

  // UI Preferences — theme, font, accent (cross-device sync)
  preferences Json?

  // Notifications & Earnings
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  creatorEarnings         CreatorEarning[]
  buyerEarnings           CreatorEarning[]         @relation("BuyerEarnings")

  // Generated Assets
  generatedAssets GeneratedAsset[]

  // Game DNA Scanner
  gameScans GameScan[]

  // Team Collaboration
  ownedTeams      Team[]           @relation("OwnedTeams")
  teamMemberships TeamMember[]
  sentInvites     TeamInvite[]     @relation("SentInvites")
  teamActivities  TeamActivity[]   @relation("TeamActivities")
  projectVersions ProjectVersion[] @relation("ProjectVersions")

  // Builds & Projects
  builds   Build[]
  projects Project[]

  // Site Reviews (homepage testimonials)
  siteReviews SiteReview[]

  // Token Grant Jobs
  tokenGrantJobs TokenGrantJob[]

  // Gifts
  giftsSent     Gift[] @relation("GiftsSent")
  giftsReceived Gift[] @relation("GiftsReceived")

  // Beta program — gates editor access when BETA_REQUIRED=true
  betaAccess          Boolean      @default(false)
  betaInvitesCreated  BetaInvite[] @relation("BetaInvitesCreated")
  betaInvitesRedeemed BetaInvite[] @relation("BetaInvitesRedeemed")
  // BUG 4: newsletters composed in the admin dashboard
  newslettersCreated  Newsletter[] @relation("NewslettersCreated")

  @@index([deletedAt])
  @@index([parentConsentTokenExp])
}

enum UserRole {
  USER
  ADMIN
  CREATOR
  MODERATOR
}

// ─── Subscriptions & Billing ───────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  tier                 SubscriptionTier   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  trialEnd             DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([status])
  @@index([status, currentPeriodEnd])
}

enum SubscriptionTier {
  FREE
  HOBBY
  CREATOR
  STUDIO
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAUSED
  UNPAID
}

// ─── Token Economy ─────────────────────────────────────────────────────────

model TokenBalance {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance        Int      @default(0)
  lifetimeEarned Int      @default(0)
  lifetimeSpent  Int      @default(0)
  rolloverTokens Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  transactions TokenTransaction[]
}

model TokenTransaction {
  id          String               @id @default(cuid())
  balanceId   String
  balance     TokenBalance         @relation(fields: [balanceId], references: [id], onDelete: Cascade)
  type        TokenTransactionType
  amount      Int
  description String
  metadata    Json?
  createdAt   DateTime             @default(now())

  @@index([balanceId])
  @@index([createdAt])
  @@index([type])
  @@index([balanceId, createdAt])
}

enum TokenTransactionType {
  PURCHASE
  SPEND
  REFUND
  BONUS
  ROLLOVER
  SUBSCRIPTION_GRANT
  EXPIRY
}

// ─── Charity ───────────────────────────────────────────────────────────────

model CharityDonation {
  id               String            @id @default(cuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  stripeTransferId String?           @unique
  charitySlug      String
  charityName      String
  amountCents      Int
  sourcePurchaseId String?           @unique
  sourcePurchase   TemplatePurchase? @relation(fields: [sourcePurchaseId], references: [id], onDelete: SetNull)
  status           DonationStatus    @default(PENDING)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  processedAt      DateTime?

  @@index([userId])
  @@index([createdAt])
  @@index([status])
}

enum DonationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

// ─── Audit Logging ─────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  resource   String
  resourceId String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([resource, resourceId])
  @@index([resource, resourceId, createdAt])
  @@index([userId, createdAt])
}

// ─── API Usage Tracking ────────────────────────────────────────────────────

model ApiUsageRecord {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Optional: tracks which API key triggered this record (null = session-based)
  apiKeyId     String?
  apiKey       ApiKey?  @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  provider     String
  operation    String
  // HTTP method + path for per-key endpoint analytics
  httpMethod   String?
  httpPath     String?
  statusCode   Int?
  tokensUsed   Int      @default(0)
  // Stored as micro-dollars (Int) to avoid float precision issues
  costUsdMicro Int      @default(0)
  durationMs   Int?
  success      Boolean  @default(true)
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([apiKeyId])
  @@index([provider])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([apiKeyId, createdAt])
  @@index([httpPath, createdAt])
}

// ─── Cost Tracking (aggregated daily) ──────────────────────────────────────

model DailyCostSnapshot {
  id                String   @id @default(cuid())
  date              DateTime @unique @db.Date
  providerCosts     Json
  // Stored as micro-dollars (Int) to avoid float precision issues
  totalCostUsdMicro Int
  totalRevenueMicro Int
  marginMicro       Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ─── Marketplace ────────────────────────────────────────────────────────────

enum TemplateCategory {
  GAME_TEMPLATE
  MAP_TEMPLATE
  UI_KIT
  SCRIPT
  ASSET
  SOUND
  PLUGIN
}

enum TemplateStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
  TAKEDOWN
}

model Template {
  id              String           @id @default(cuid())
  creatorId       String
  creator         User             @relation("CreatedTemplates", fields: [creatorId], references: [id], onDelete: Restrict)
  title           String
  slug            String           @unique
  description     String           @db.Text
  category        TemplateCategory
  status          TemplateStatus   @default(DRAFT)
  priceCents      Int              @default(0)
  rbxmFileUrl     String?
  thumbnailUrl    String?
  tags            String[]
  downloads       Int              @default(0)
  averageRating   Float            @default(0)
  reviewCount     Int              @default(0)
  stripeProductId String?          @unique
  stripePriceId   String?          @unique
  featuredAt      DateTime?
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  screenshots     TemplateScreenshot[]
  reviews         TemplateReview[]
  purchases       TemplatePurchase[]
  creatorEarnings CreatorEarning[]

  // Social / Gallery
  likes      TemplateLike[]
  favorites  TemplateFavorite[]
  forks      TemplateFork[]     @relation("OriginalTemplate")
  forkedFrom TemplateFork[]     @relation("ForkedTemplate")
  likeCount  Int                @default(0)
  forkCount  Int                @default(0)
  viewCount  Int                @default(0)
  trending   Float              @default(0) // Calculated trending score
  featured   Boolean            @default(false)

  @@index([creatorId])
  @@index([category])
  @@index([status])
  @@index([createdAt])
  @@index([averageRating])
  @@index([downloads])
  @@index([deletedAt])
  @@index([featuredAt])
  @@index([priceCents])
  // Composite indexes for common browse/filter patterns
  @@index([status, category])
  @@index([status, createdAt])
  @@index([status, averageRating])
  @@index([status, downloads])
  @@index([creatorId, createdAt])
  @@index([creatorId, status])
  @@index([trending])
  @@index([likeCount])
  @@index([forkCount])
  @@index([featured])
}

// ─── Social / Gallery ──────────────────────────────────────────────────────

model TemplateLike {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  createdAt DateTime @default(now())

  item Template @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([itemId])
  @@index([userId])
}

model TemplateFavorite {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  createdAt DateTime @default(now())

  item Template @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId])
}

model TemplateFork {
  id             String   @id @default(cuid())
  userId         String
  originalItemId String
  forkedItemId   String
  createdAt      DateTime @default(now())

  originalItem Template @relation("OriginalTemplate", fields: [originalItemId], references: [id])
  forkedItem   Template @relation("ForkedTemplate", fields: [forkedItemId], references: [id])

  @@index([originalItemId])
  @@index([userId])
  @@index([forkedItemId])
}

model TemplateScreenshot {
  id         String   @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  url        String
  altText    String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([templateId])
  @@index([templateId, sortOrder])
}

model TemplateReview {
  id              String           @id @default(cuid())
  templateId      String
  template        Template         @relation(fields: [templateId], references: [id], onDelete: Cascade)
  reviewerId      String?
  // SetNull rather than Cascade: reviews are shared content that affect template ratings/counts.
  // Deleting a user must not silently wipe other creators' review histories or template averages.
  reviewer        User?            @relation("AuthoredReviews", fields: [reviewerId], references: [id], onDelete: SetNull)
  purchaseId      String           @unique
  purchase        TemplatePurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  rating          Int
  body            String?          @db.Text
  creatorResponse String?          @db.Text
  respondedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([templateId])
  @@index([reviewerId])
  @@index([rating])
  @@index([templateId, createdAt])
  @@index([templateId, rating])
}

model TemplatePurchase {
  id                    String       @id @default(cuid())
  templateId            String
  template              Template     @relation(fields: [templateId], references: [id], onDelete: Restrict)
  buyerId               String
  buyer                 User         @relation("BoughtTemplates", fields: [buyerId], references: [id], onDelete: Restrict)
  stripePaymentIntentId String?      @unique
  amountCents           Int
  platformFeeCents      Int
  creatorPayoutCents    Int
  stripeTransferId      String?      @unique
  payoutStatus          PayoutStatus @default(PENDING)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  review          TemplateReview?
  charityDonation CharityDonation?

  @@unique([templateId, buyerId])
  @@index([templateId])
  @@index([buyerId])
  @@index([createdAt])
  @@index([payoutStatus])
  @@index([buyerId, createdAt])
  @@index([templateId, payoutStatus])
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
  FROZEN
}

model CreatorAccount {
  id                  String    @id @default(cuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeAccountId     String    @unique
  chargesEnabled      Boolean   @default(false)
  payoutsEnabled      Boolean   @default(false)
  detailsSubmitted    Boolean   @default(false)
  pendingBalanceCents Int       @default(0)
  totalEarnedCents    Int       @default(0)
  lastPayoutAt        DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// ─── Gamification ───────────────────────────────────────────────────────────

model UserXP {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalXp      Int      @default(0)
  tier         XPTier   @default(NOVICE)
  dailyXpToday Int      @default(0)
  dailyXpDate  DateTime @default(now()) @db.Date
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  xpEvents XPEvent[]

  @@index([totalXp])
  @@index([tier])
}

enum XPTier {
  NOVICE
  APPRENTICE
  BUILDER
  MASTER
  LEGEND
  MYTHIC
}

enum XPEventType {
  BUILD
  PUBLISH
  SALE
  REFERRAL
  ACHIEVEMENT
  STREAK_BONUS
  DAILY_LOGIN
  REVIEW_GIVEN
  PURCHASE
}

model XPEvent {
  id        String      @id @default(cuid())
  userXpId  String
  userXp    UserXP      @relation(fields: [userXpId], references: [id], onDelete: Cascade)
  type      XPEventType
  amount    Int
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([userXpId])
  @@index([createdAt])
  @@index([type])
  @@index([userXpId, createdAt])
}

model Achievement {
  id          String              @id @default(cuid())
  slug        String              @unique
  name        String
  description String
  icon        String
  category    AchievementCategory
  xpReward    Int                 @default(0)
  condition   Json
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  userAchievements UserAchievement[]
}

enum AchievementCategory {
  FIRST_STEPS
  VELOCITY
  MARKETPLACE
  COMMUNITY
  QUALITY
  EXPLORATION
  SOCIAL
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Restrict)
  unlockedAt    DateTime    @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
}

model Streak {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  loginStreak        Int      @default(0)
  buildStreak        Int      @default(0)
  longestLoginStreak Int      @default(0)
  longestBuildStreak Int      @default(0)
  lastLoginDate      DateTime @default(now()) @db.Date
  lastBuildDate      DateTime @default(now()) @db.Date
  totalLogins        Int      @default(0)
  totalBuilds        Int      @default(0)
  // JSON array of milestone day-counts already rewarded e.g. [7, 30]
  // Prevents re-earning the same milestone if streak drops and rebuilds.
  claimedMilestones  Json     @default("[]")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
}

// ─── Game DNA Scanner ──────────────────────────────────────────────────────

model GameScan {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  robloxUrl     String
  robloxPlaceId String?
  gameName      String?
  status        ScanStatus @default(PENDING)
  errorMsg      String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  genome GameGenome?

  @@index([userId])
  @@index([createdAt])
  @@index([robloxPlaceId])
  @@index([status])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([robloxPlaceId, status])
}

enum ScanStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
  CANCELLED
}

model GameGenome {
  id     String   @id @default(cuid())
  scanId String   @unique
  scan   GameScan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  // 12-variable genome
  gameType          String
  targetAge         String
  sessionLength     String
  monetizationModel String
  progressionPace   String
  zoneDensity       String
  artStyle          String
  retentionDriver   String
  estimatedDau      String
  engagementLoop    String
  updateCadence     String
  communitySize     String

  // Raw scores 0-100 for radar chart
  scores Json

  // Genre averages for comparison
  genreAverages Json?

  // Analysis metadata
  rawRobloxData   Json?
  visionAnalysis  Json?
  recommendations Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Team Collaboration ────────────────────────────────────────────────────
//
// SOFT-DELETE CONSISTENCY: Every query against `Team` must include
// `where: { deletedAt: null }` to exclude soft-deleted teams.
//
// TODO: Replace manual filters with a Prisma $extends global query filter:
//   prisma.$extends({
//     query: {
//       team: {
//         async findMany({ args, query }) {
//           args.where = { ...args.where, deletedAt: null }
//           return query(args)
//         },
//       },
//     },
//   })
// This eliminates the risk of accidentally reading deleted teams.

model Team {
  id          String    @id @default(cuid())
  name        String
  description String?
  slug        String    @unique
  ownerId     String
  owner       User      @relation("OwnedTeams", fields: [ownerId], references: [id], onDelete: Restrict)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members    TeamMember[]
  invites    TeamInvite[]
  versions   ProjectVersion[]
  activities TeamActivity[]
  projects   Project[]

  @@index([ownerId])
  @@index([deletedAt])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      TeamRole @default(VIEWER)
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  lockedZones ZoneLock[]

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

enum TeamRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

model TeamInvite {
  id         String       @id @default(cuid())
  teamId     String
  team       Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedBy  String?
  // SetNull rather than Cascade: the invite should survive the inviter's account deletion
  // so existing pending invites can still be accepted or expired naturally.
  inviter    User?        @relation("SentInvites", fields: [invitedBy], references: [id], onDelete: SetNull)
  email      String?
  token      String       @unique @default(cuid())
  role       TeamRole     @default(EDITOR)
  status     InviteStatus @default(PENDING)
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([teamId])
  @@index([email])
  @@index([status])
  @@index([expiresAt])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model TeamActivity {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId      String?
  // SetNull rather than Cascade: team activity logs are audit records.
  // Deleting a user must not erase the team's history of what was done.
  actor       User?    @relation("TeamActivities", fields: [userId], references: [id], onDelete: SetNull)
  action      String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([teamId])
  @@index([userId])
  @@index([createdAt])
  @@index([teamId, createdAt])
}

model ZoneLock {
  id           String     @id @default(cuid())
  teamMemberId String
  member       TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  zoneId       String     @unique
  zoneName     String?
  lockedAt     DateTime   @default(now())
  expiresAt    DateTime
  updatedAt    DateTime   @updatedAt

  @@index([teamMemberId])
  @@index([expiresAt])
}

model ProjectVersion {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  projectId String
  userId    String?
  // SetNull rather than Cascade: project versions are team-owned history.
  // Deleting a team member must not destroy the version snapshots other members depend on.
  author    User?    @relation("ProjectVersions", fields: [userId], references: [id], onDelete: SetNull)
  version   Int
  message   String?
  snapshot  Json
  createdAt DateTime @default(now())

  diffs   VersionDiff[] @relation("FromVersion")
  diffsTo VersionDiff[] @relation("ToVersion")

  @@unique([teamId, projectId, version])
  @@index([teamId])
  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
  @@index([teamId, projectId, createdAt])
}

model VersionDiff {
  id            String         @id @default(cuid())
  fromVersionId String
  fromVersion   ProjectVersion @relation("FromVersion", fields: [fromVersionId], references: [id], onDelete: Cascade)
  toVersionId   String
  toVersion     ProjectVersion @relation("ToVersion", fields: [toVersionId], references: [id], onDelete: Cascade)
  diff          Json
  summary       String?
  createdAt     DateTime       @default(now())

  @@index([fromVersionId])
  @@index([toVersionId])
}

// ─── API Keys ───────────────────────────────────────────────────────────────

model ApiKey {
  id                     String     @id @default(cuid())
  userId                 String
  user                   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                   String
  keyHash                String     @unique
  prefix                 String
  scopes                 String[]
  tier                   ApiKeyTier @default(FREE)
  revokedAt              DateTime?
  lastUsedAt             DateTime?
  expiresAt              DateTime?
  // Rotation: if set, this key was created by rotating rotatedFromId; that old key
  // remains valid until rotatedFromGraceEndsAt (24-hour window) then is auto-revoked.
  rotatedFromId          String?    @unique
  rotatedFrom            ApiKey?    @relation("ApiKeyRotation", fields: [rotatedFromId], references: [id], onDelete: SetNull)
  rotatedTo              ApiKey?    @relation("ApiKeyRotation")
  rotatedFromGraceEndsAt DateTime?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  usageRecords ApiUsageRecord[]

  @@index([userId])
  @@index([prefix])
  @@index([revokedAt])
  // Composite: look up active (non-revoked) keys for a user
  @@index([userId, revokedAt])
  @@index([rotatedFromGraceEndsAt])
}

enum ApiKeyTier {
  FREE
  HOBBY
  CREATOR
  STUDIO
}

// ─── Webhooks ───────────────────────────────────────────────────────────────

model WebhookEndpoint {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url       String
  // SECURITY: `secret` must be stored as an HMAC-SHA256 hash, never in plaintext.
  // On creation: hash with crypto.createHmac('sha256', WEBHOOK_SECRET_SALT).update(rawSecret).digest('hex')
  // On delivery: sign the payload with the raw secret obtained at creation time (never re-read from DB).
  // The raw secret is shown to the user exactly once at creation and never stored.
  secret    String
  events    String[]
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveries WebhookDelivery[]

  @@index([userId])
  @@index([active])
}

model WebhookDelivery {
  id           String          @id @default(cuid())
  endpointId   String
  endpoint     WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  event        String
  payload      Json
  statusCode   Int?
  responseBody String?
  attempt      Int             @default(1)
  success      Boolean         @default(false)
  nextRetryAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([endpointId])
  @@index([createdAt])
  @@index([success, nextRetryAt])
  @@index([endpointId, success, nextRetryAt])
}

// ─── Referrals ──────────────────────────────────────────────────────────────

model Referral {
  id              String         @id @default(cuid())
  referrerId      String
  referrer        User           @relation("ReferrerReferrals", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId      String?
  referred        User?          @relation("ReferredReferrals", fields: [referredId], references: [id], onDelete: SetNull)
  code            String         @unique
  status          ReferralStatus @default(PENDING)
  // Stored as cents (Int) to avoid float precision issues
  commissionCents Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  convertedAt     DateTime?

  @@unique([referrerId, referredId])
  @@index([referrerId])
  @@index([referredId])
  @@index([referrerId, status])
}

enum ReferralStatus {
  PENDING
  CONVERTED
  PAID
  EXPIRED
  INVALID
}

// ─── Waitlist ───────────────────────────────────────────────────────────

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("download_page")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([source])
  @@index([createdAt])
}

// ─── Notifications ──────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  readAt    DateTime?
  actionUrl String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId])
  @@index([userId, read])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([userId, read, createdAt])
}

enum NotificationType {
  BUILD_COMPLETE
  BUILD_FAILED
  TOKEN_LOW
  TOKEN_DEPLETED
  SALE
  REFERRAL_EARNED
  TEAM_INVITE
  ACHIEVEMENT_UNLOCKED
  SYSTEM
  WEEKLY_DIGEST
  TEMPLATE_PURCHASED
  PAYOUT_COMPLETED
  REVIEW_RECEIVED
  PAYOUT_FAILED
  LFG_JOIN_REQUEST
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
}

// ─── Notification Preferences ────────────────────────────────────────────────

model NotificationPreference {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  channel   NotificationChannel
  enabled   Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([userId, type, channel])
  @@index([userId])
}

// ─── Creator Earnings ────────────────────────────────────────────────────────

model CreatorEarning {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  templateId   String?
  template     Template?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  templateName String?
  amountCents  Int
  netCents     Int
  buyerId      String?
  buyer        User?         @relation("BuyerEarnings", fields: [buyerId], references: [id], onDelete: SetNull)
  status       EarningStatus @default(PENDING)
  paidAt       DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([templateId, buyerId])
  @@index([userId])
  @@index([createdAt])
  @@index([userId, status])
  @@index([status])
  @@index([templateId])
  @@index([buyerId])
  @@index([userId, createdAt])
}

enum EarningStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
  FROZEN
}

// ─── Token Grant Jobs (async webhook processing) ────────────────────────────

model TokenGrantJob {
  id          String               @id @default(cuid())
  userId      String
  user        User                 @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
  amount      Int
  type        TokenTransactionType
  description String
  metadata    Json?
  invoiceId   String?
  sessionId   String?
  status      TokenGrantJobStatus  @default(PENDING)
  attempts    Int                  @default(0)
  lastError   String?
  processedAt DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([userId])
  @@index([status])
  @@index([invoiceId])
  @@index([sessionId])
  @@index([status, createdAt])
}

enum TokenGrantJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── Generated Assets (Meshy 3D pipeline) ────────────────────────────────────

model GeneratedAsset {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt String @db.Text
  type   String // mesh | music | sfx | voice | texture | animation | building | character | vehicle, etc.
  style  String @default("default") // realistic, stylized, lowpoly, roblox

  // queued → generating → optimizing → uploading → ready | failed | pending_moderation
  status String @default("queued")

  // Meshy
  meshyTaskId  String? @unique
  meshUrl      String?
  thumbnailUrl String?
  polyCount    Int?

  // Textures
  albedoUrl    String?
  normalUrl    String?
  roughnessUrl String?
  metallicUrl  String?

  // Roblox
  robloxAssetId String?

  // Audio + generic provider fields (FAL request id, Meshy task id, etc.)
  externalTaskId  String?
  sourceUrl       String? // mp3/glb/etc — original provider URL before Roblox upload
  moderationState String? // 'reviewing' | 'approved' | 'rejected'
  durationMs      Int?
  metadata        Json?

  // Quality
  qualityScore Float?
  fileSize     Int?

  // Metadata
  tokensCost   Int     @default(0)
  generationMs Int?
  errorMessage String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([userId])
  @@index([status])
  @@index([meshyTaskId])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([userId, type, createdAt])
}

// ─── Builds ──────────────────────────────────────────────────────────────────

model Build {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  buildType  String   @default("general")
  prompt     String   @db.Text
  tokensUsed Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([projectId])
  @@index([userId, createdAt])
  @@index([createdAt])
}

// ─── Projects ─────────────────────────────────────────────────────────────────

model Project {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId    String?
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  name      String
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  builds Build[]

  @@index([userId])
  @@index([teamId])
  @@index([userId, archived])
}

// ─── Gifts ────────────────────────────────────────────────────────────────────

model Gift {
  id              String    @id @default(cuid())
  senderId        String
  sender          User      @relation("GiftsSent", fields: [senderId], references: [id])
  recipientEmail  String
  giftType        String // 'subscription' or 'tokens'
  tier            String? // for subscription gifts
  tokenAmount     Int? // for token gifts
  message         String?
  status          String    @default("pending") // pending, redeemed, expired
  stripeSessionId String?   @unique
  redeemCode      String    @unique
  redeemedById    String?
  redeemedBy      User?     @relation("GiftsReceived", fields: [redeemedById], references: [id])
  redeemedAt      DateTime?
  expiresAt       DateTime
  createdAt       DateTime  @default(now())

  @@index([senderId])
  @@index([recipientEmail])
  @@index([redeemCode])
  @@index([status])
  @@index([expiresAt])
}

// ─── RAG Knowledge Base ──────────────────────────────────────────────────────
// Vector-embedded Roblox documentation chunks for retrieval-augmented generation.
// Embedding column (vector(768)) is managed via raw SQL — Prisma doesn't support pgvector natively.
// Use db.$queryRawUnsafe() for vector similarity searches.

model RobloxDocChunk {
  id        String   @id @default(cuid())
  category  String // e.g. "api", "luau", "service", "pattern", "devforum"
  title     String // e.g. "Terrain:FillBlock", "DataStoreService best practices"
  content   String // The actual documentation text
  source    String   @default("") // URL or reference
  tags      String[] @default([])
  // embedding vector(768) — managed via raw SQL migration, not in Prisma schema
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, title])
  @@index([category])
}

// ─── Chat Session Persistence ─────────────────────────────────────────────────
// Cloud-synced chat sessions so conversations survive across devices / browsers.

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String        @default("New Chat")
  aiMode    String        @default("build")
  model     String        @default("claude-3-5-sonnet")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@index([userId, updatedAt(sort: Desc)])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String // 'user' | 'assistant' | 'system'
  content   String      @db.Text
  metadata  Json? // tokens, model, etc.
  timestamp DateTime    @default(now())

  @@index([sessionId, timestamp])
}

// ─── Beta Program ──────────────────────────────────────────────────────────
// Invite-only beta rollout. Admins generate codes in batches (cohorts), users
// redeem them via /api/beta/invite, and access to /editor is gated by the
// withBetaGuard helper when BETA_REQUIRED=true.

model BetaInvite {
  id           String    @id @default(cuid())
  code         String    @unique
  createdById  String? // Admin who created it (null if system-generated)
  createdBy    User?     @relation("BetaInvitesCreated", fields: [createdById], references: [id], onDelete: SetNull)
  usedById     String? // User who redeemed it (first redeemer for single-use; null otherwise)
  usedBy       User?     @relation("BetaInvitesRedeemed", fields: [usedById], references: [id], onDelete: SetNull)
  usedAt       DateTime?
  expiresAt    DateTime?
  maxUses      Int       @default(1)
  useCount     Int       @default(0)
  bonusCredits Int       @default(0) // Bonus credits granted on redemption
  cohort       String? // 'youtuber', 'roblox-dev', 'studio-team', etc.
  createdAt    DateTime  @default(now())

  @@index([code])
  @@index([cohort])
}

/// BUG 4: Newsletter composer — tracks drafts, scheduled sends, and sent
/// batches surfaced in the admin dashboard. Keep schema additive so the
/// migration is a safe ADD TABLE without touching existing data.
model Newsletter {
  id             String    @id @default(cuid())
  subject        String
  htmlContent    String    @db.Text
  status         String    @default("draft") // draft, scheduled, sent
  scheduledAt    DateTime?
  sentAt         DateTime?
  recipientCount Int?
  createdById    String
  createdBy      User      @relation("NewslettersCreated", fields: [createdById], references: [id])
  createdAt      DateTime  @default(now())

  @@index([status, createdAt])
}

// ─── Build Feedback (Luau Verifier) ───────────────────────────────────────

/// Persists user feedback on AI-generated Luau builds.
/// Replaces the in-memory-only recentFeedback array in luau-verifier.ts
/// so data survives lambda restarts and is queryable for quality metrics.
model BuildFeedback {
  id           String   @id @default(cuid())
  promptHash   String
  prompt       String?  @db.Text    // Original user prompt (for few-shot retrieval)
  code         String   @db.Text
  worked       Boolean
  errorMessage String?
  score        Int
  model        String
  category     String?              // Detected genre/theme (medieval, sci-fi, etc.)
  partCount    Int?                 // Number of parts in the build
  userVote     Boolean?             // null=no vote, true=user said "worked", false=user said "broke"
  playtestPass Boolean?             // null=not tested, true=playtest passed, false=playtest found errors
  buildType    String?  @default("build") // build, script, terrain, image, mesh
  // embedding vector(768) — managed via raw SQL, not in Prisma schema (same as RobloxDocChunk)
  createdAt    DateTime @default(now())

  @@index([promptHash])
  @@index([worked, score])
  @@index([category, score])
  @@index([userVote])
}

// ─── Site Reviews (homepage testimonials) ─────────────────────────────────────
model SiteReview {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  review    String   @db.VarChar(200)
  stars     Int      // 1-5
  approved  Boolean  @default(false) // manual approval before showing on homepage
  createdAt DateTime @default(now())

  @@index([approved, createdAt])
  @@index([userId])
}

// ─── AI Error Learning ────────────────────────────────────────────────────

model ScriptErrorLog {
  id           String   @id @default(cuid())
  sessionId    String?
  userId       String?
  errorMessage String   @db.Text
  errorType    String   // "syntax" | "runtime" | "timeout" | "hallucination"
  originalCode String   @db.Text
  fixedCode    String?  @db.Text
  fixAttempt   Int      @default(1)
  fixSucceeded Boolean  @default(false)
  model        String?
  prompt       String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([errorType])
  @@index([fixSucceeded])
  @@index([createdAt])
}

// ─── LFG (Looking For Group) ───────────────────────────────────────────────

model LfgPost {
  id             String   @id @default(cuid())
  userId         String
  title          String
  description    String
  gameType       String   // tycoon, simulator, obby, rpg, horror, etc.
  lookingFor     String   // builders, scripters, ui-designers, etc.
  maxMembers     Int      @default(4)
  currentMembers Int      @default(1)
  status         String   @default("open") // open, full, closed
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  expiresAt      DateTime // auto-close after 24h

  @@index([status, gameType])
  @@index([userId])
  @@index([expiresAt])
}

// Community feed — public posting channel for finding people, sharing builds, chatting
model FeedPost {
  id        String      @id @default(cuid())
  userId    String
  content   String      // the message (max 500 chars)
  channel   String      @default("general") // general, looking-for-team, showcase, help
  likes     Int         @default(0)
  replyToId String?     // parent post ID for threading
  replyTo   FeedPost?   @relation("FeedReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   FeedPost[]  @relation("FeedReplies")
  replyCount Int        @default(0)
  createdAt DateTime    @default(now())

  @@index([channel, createdAt])
  @@index([userId])
  @@index([replyToId])
}

// Track who liked what (prevents double-likes)
model FeedLike {
  id     String @id @default(cuid())
  postId String
  userId String

  @@unique([postId, userId])
  @@index([postId])
}
