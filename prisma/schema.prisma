model Build {
  id         String   @id @default(cuid())
  userId     String
  buildType  String   @default("general")
  prompt     String   @db.Text
  tokensUsed Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([userId, createdAt])
  @@index([createdAt])
}

