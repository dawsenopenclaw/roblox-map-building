{
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "crons": [
    {
      "path": "/api/internal/cost-snapshot",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/internal/cron/weekly-digest",
      "schedule": "0 9 * * 0"
    },
    {
      "path": "/api/internal/cron/re-engagement",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/internal/cron/coppa-annual-notice",
      "schedule": "0 8 1 1 *"
    },
    {
      "path": "/api/internal/cron/webhook-dlq-cleanup",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/internal/cron/webhook-retry",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/internal/cron/notification-archive",
      "schedule": "0 3 * * *"
    }
  ]
}
